      "email": { "type": "jsonpath", "path": "'dcat:contactPoint'.'vcard:hasEmail'.'@id'" }
    },
    "species": {
      "type": "literal",
      "value": ""
    },
    "temporal": {
      "year_begin": { "type": "jsonpath", "path": "'dcterms:temporal'.'time:hasBeginning'.'time:inXSDgYear'" },
      "year_end": { "type": "jsonpath", "path": "'dcterms:temporal'.'time:hasEnd'.'time:inXSDgYear'" }
